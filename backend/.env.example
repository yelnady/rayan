# Google Cloud
GOOGLE_CLOUD_PROJECT=rayan-memory
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase (for token verification)
FIREBASE_PROJECT_ID=rayan-memory

# Vertex AI Vector Search
VERTEX_AI_INDEX_ENDPOINT=projects/rayan-memory/locations/us-central1/indexEndpoints/YOUR_ENDPOINT_ID
VERTEX_AI_DEPLOYED_INDEX_ID=artifact-embeddings

# Cloud Storage
MEDIA_BUCKET=rayan-media-rayan-memory

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
